# OverTime secrets — convenience file for local development.
#
# Preferred approach: export secrets as environment variables in your
# shell (e.g. export PM_PASSWORD=...).  Environment variables work
# regardless of the backend setting and don't leave secrets on disk.
#
# Alternative: copy this file to .env and fill in values.
# Set secrets.backend = dotenv in your provisioning spec to read from it.
#
# In provisioning specs, reference secrets with ${secret:key_name}.
# 1Password users can use op:// paths instead (e.g. ${secret:op://vault/item/field}).

# Proxmox VE — use ONE of password or API token
pm_password=
# pm_api_token=

# Ansible connection password (for Windows WinRM / Linux SSH fallback)
ansible_password=

# SSH public key for Linux VMs (optional — can also be inlined in spec)
# ssh_pub_key=ssh-ed25519 AAAAC3...
